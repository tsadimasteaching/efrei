flowchart TB
    subgraph pod ["Kubernetes Pod"]
        direction TB
        init["<b>Init Container</b><br/>(Vault Agent)<br/><br/>1. Auth to Vault via K8s SA<br/>2. Fetch secrets<br/>3. Write to shared volume"]
        vol[("<b>Shared Volume</b><br/>/vault/secrets/<br/><br/>db-password = s3cr3t<br/>api-key = k3y...")]
        app["<b>App Container</b><br/><br/>reads /vault/secrets/db-pw<br/>(no Vault SDK needed)"]

        init -- "writes secrets" --> vol
        vol -- "mounted as files" --> app
    end

    vault[("<b>HashiCorp Vault</b><br/><br/>Authenticates Pod's<br/>Service Account via<br/>K8s auth method")]

    vault -- "returns secrets" --> init
    init -. "auth request<br/>(K8s ServiceAccount token)" .-> vault

    style pod fill:#e8f4f8,stroke:#2196F3,stroke-width:2px
    style init fill:#fff3e0,stroke:#FF9800,stroke-width:2px
    style vol fill:#e8f5e9,stroke:#4CAF50,stroke-width:2px
    style app fill:#e3f2fd,stroke:#1976D2,stroke-width:2px
    style vault fill:#fce4ec,stroke:#E53935,stroke-width:2px
